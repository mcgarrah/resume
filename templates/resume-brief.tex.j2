% Colors
\definecolor{accent}{HTML}{4B6A78}
\definecolor{heading}{HTML}{222222}
\definecolor{subtext}{HTML}{555555}
\definecolor{rulecolor}{HTML}{333333}

% Fonts (requires XeLaTeX)
\defaultfontfeatures{Ligatures=TeX}
\IfFontExistsTF{Helvetica Neue}{%
  \setmainfont{Helvetica Neue}[
    BoldFont=* Bold,
    ItalicFont=* Italic,
    BoldItalicFont=* Bold Italic,
  ]
}{%
  \setmainfont{TeX Gyre Heros}[
    BoldFont=* Bold,
    ItalicFont=* Italic,
    BoldItalicFont=* Bold Italic,
  ]
}

% Hyperlink setup
\hypersetup{
  colorlinks=true,
  linkcolor=accent,
  urlcolor=accent,
  pdfauthor={<< sidebar.name >>},
  pdftitle={<< sidebar.name >> — Resume (Brief)},
}

% Section formatting
\titleformat{\section}
  {\large\bfseries\color{heading}\MakeTextUppercase}
  {}{0em}{}
  [\vspace{-0.5em}{\color{rulecolor}\rule{\linewidth}{1.5pt}}]

\titleformat{\subsection}
  {\normalsize\bfseries\color{heading}}
  {}{0em}{}

\titlespacing*{\section}{0pt}{12pt}{6pt}
\titlespacing*{\subsection}{0pt}{8pt}{2pt}

% Custom commands
\newcommand{\jobtitle}[4]{%
  \needspace{4\baselineskip}%
  \subsection[#1]{\href{https://mcgarrah.org/resume/print/\##4}{#1} \hfill \small\textcolor{subtext}{#2}}%
  \vspace{-2pt}%
  {\small\textcolor{subtext}{#3}}%
  \vspace{4pt}%
}

\newcommand{\edutitle}[5]{%
  \needspace{4\baselineskip}%
  \subsection[#1]{\href{https://mcgarrah.org/resume/print/\##5}{#1} \hfill \small\textcolor{subtext}{#2}}%
  \vspace{-2pt}%
  {\small\textcolor{subtext}{#3<< "\\hfill GPA: " if "#4" != "" >>#4}}%
  \vspace{4pt}%
}

% Headers and footers
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[C]{\small\color{subtext} << sidebar.name >> --- Resume (Brief)}
\fancyfoot[C]{\small\color{subtext} Page \thepage\ of \pageref{LastPage}}

\fancypagestyle{firstpage}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\small\color{subtext} Page \thepage\ of \pageref{LastPage}}%
}

% Reduce list spacing
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=2pt}

\begin{document}
\thispagestyle{firstpage}

