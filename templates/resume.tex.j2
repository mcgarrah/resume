%% Resume LaTeX Template — Generated from _data/data.yml via Jinja2
%% Compile with: xelatex or pdflatex
\documentclass[11pt,letterpaper]{article}

% Packages
\usepackage[margin=0.7in]{geometry}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage{hyperref}
\usepackage{multicol}
\usepackage{xcolor}
\usepackage{fontspec}
\usepackage{parskip}
\usepackage{needspace}  % Prevent orphaned section headers
\usepackage{fancyhdr}   % Custom headers and footers
\usepackage{lastpage}   % Total page count
\usepackage{graphicx}   % Image inclusion
\usepackage{textcomp}   % Additional text symbols

% Colors
\definecolor{accent}{HTML}{4B6A78}
\definecolor{heading}{HTML}{222222}
\definecolor{subtext}{HTML}{555555}
\definecolor{rulecolor}{HTML}{333333}

% Fonts (requires XeLaTeX)
% Helvetica Neue on macOS; TeX Gyre Heros (Helvetica clone) on Linux/CI
\defaultfontfeatures{Ligatures=TeX}
\IfFontExistsTF{Helvetica Neue}{%
  \setmainfont{Helvetica Neue}[
    BoldFont=* Bold,
    ItalicFont=* Italic,
    BoldItalicFont=* Bold Italic,
  ]
}{%
  \setmainfont{TeX Gyre Heros}[
    BoldFont=* Bold,
    ItalicFont=* Italic,
    BoldItalicFont=* Bold Italic,
  ]
}

% Hyperlink setup
\hypersetup{
  colorlinks=true,
  linkcolor=accent,
  urlcolor=accent,
  pdfauthor={<< sidebar.name >>},
  pdftitle={<< sidebar.name >> — Resume},
}

% Section formatting
\titleformat{\section}
  {\large\bfseries\color{heading}\MakeTextUppercase}
  {}{0em}{}
  [\vspace{-0.5em}{\color{rulecolor}\rule{\linewidth}{1.5pt}}]

\titleformat{\subsection}
  {\normalsize\bfseries\color{heading}}
  {}{0em}{}

\titleformat{\subsubsection}
  {\small\bfseries\itshape\color{subtext}}
  {}{0em}{}

\titlespacing*{\section}{0pt}{12pt}{6pt}
\titlespacing*{\subsection}{0pt}{8pt}{2pt}
\titlespacing*{\subsubsection}{0pt}{6pt}{2pt}

% Custom commands
% \needspace ensures headings don't appear orphaned at page bottom

% Logo path for company/university logos
\graphicspath{{assets/images/company-logos/latex-logos/}}

% Logo-to-anchor mapping (used by Jinja2 template)
% Placeholder box for entries without logos
\newcommand{\logoplaceholder}{%
  \fcolorbox{subtext}{white}{\makebox[0.7cm][c]{\rule{0pt}{0.7cm}}}%
}

\newcommand{\jobtitle}[4]{%
  \needspace{4\baselineskip}%
  \noindent\begin{minipage}[t]{0.06\textwidth}%
    \vspace{0pt}%
    \IfFileExists{#4.png}{\includegraphics[width=0.8cm,height=0.8cm,keepaspectratio]{#4}}%
      {\IfFileExists{#4.jpg}{\includegraphics[width=0.8cm,height=0.8cm,keepaspectratio]{#4}}%
        {\logoplaceholder}}%
  \end{minipage}%
  \hfill%
  \begin{minipage}[t]{0.92\textwidth}%
    \vspace{0pt}%
    \subsection[#1]{#1 \hfill \small\textcolor{subtext}{#2}}%
    \vspace{-2pt}%
    {\small\textcolor{subtext}{#3}}%
    \vspace{4pt}%
  \end{minipage}%
  \vspace{2pt}%
}

\newcommand{\edutitle}[5]{%
  \needspace{4\baselineskip}%
  \noindent\begin{minipage}[t]{0.06\textwidth}%
    \vspace{0pt}%
    \IfFileExists{#5.png}{\includegraphics[width=0.8cm,height=0.8cm,keepaspectratio]{#5}}%
      {\IfFileExists{#5.jpg}{\includegraphics[width=0.8cm,height=0.8cm,keepaspectratio]{#5}}%
        {\logoplaceholder}}%
  \end{minipage}%
  \hfill%
  \begin{minipage}[t]{0.92\textwidth}%
    \vspace{0pt}%
    \subsection[#1]{#1 \hfill \small\textcolor{subtext}{#2}}%
    \vspace{-2pt}%
    {\small\textcolor{subtext}{#3<< "\\hfill GPA: " if "#4" != "" >>#4}}%
    \vspace{4pt}%
  \end{minipage}%
  \vspace{2pt}%
}

% Headers and footers
\pagestyle{fancy}
\fancyhf{}  % Clear defaults
\renewcommand{\headrulewidth}{0pt}  % No header rule
\fancyhead[C]{\small\color{subtext} << sidebar.name >> --- Resume}
\fancyfoot[C]{\small\color{subtext} Page \thepage\ of \pageref{LastPage}}

% First page: no header, just footer
\fancypagestyle{firstpage}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\small\color{subtext} Page \thepage\ of \pageref{LastPage}}%
}

% Reduce list spacing
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=2pt}

\begin{document}
\thispagestyle{firstpage}

% === HEADER ===
\begin{center}
  {\LARGE\bfseries << sidebar.name >>}\\[4pt]
  {\normalsize\color{subtext} << sidebar.tagline >>}\\[6pt]
  {\small
    << sidebar.email >> \enspace$\cdot$\enspace
    << sidebar.phone >> \enspace$\cdot$\enspace
    \href{https://<< sidebar.website >>}{<< sidebar.website >>} \enspace$\cdot$\enspace
    \href{https://linkedin.com/in/<< sidebar.linkedin >>}{LinkedIn} \enspace$\cdot$\enspace
    \href{https://github.com/<< sidebar.github >>}{GitHub}
  }
\end{center}

\vspace{-4pt}

% === CAREER PROFILE ===
\needspace{6\baselineskip}
\section{Career Profile}
<< career_profile.summary | latex_escape >>

% === EDUCATION ===
\needspace{6\baselineskip}
\section{Education}
<% for edu in education.info %>
<% set logo_map = {"edu-uncw-2025": "uncw", "edu-gatech-2014": "georgia-tech", "edu-ncsu-1990": "ncsu-classic-1990"} %>
\edutitle{<< edu.degree | latex_escape >>}{<< edu.time >>}{<< edu.university | latex_escape >>}{<< edu.gpa | default("") >>}{<< logo_map.get(edu.anchor, "placeholder") >>}

<% if edu.summary %>
{\small << edu.summary | latex_escape | latex_paragraphs >>}
<% endif %>

<% if edu.details %>
{\small << edu.details | latex_escape | latex_paragraphs >>}
<% endif %>

<% endfor %>

% === EXPERIENCE ===
\needspace{6\baselineskip}
\section{Experience}
<% set exp_logo_map = {"envestnet-2021": "envestnet", "bcbsnc-2019": "bcbsnc", "usps-2017": "usps-eagle", "akc-2016": "akc-shield", "ncdit-2015": "nc-dit", "measurement-inc-2013": "measurement-inc", "sas-2011": "sas", "ncdor-2007": "nc-dor", "etaac-2009": "irs", "freeman-dds-1998": "placeholder", "vr-aids-2001": "placeholder", "bd-2006": "bd", "ncccs-2005": "nc-community-colleges", "hosted-solutions-2004": "tierpoint", "netiq-2002": "netiq", "ncsu-2000": "ncsu-block-s", "interpath-2000": "interpath", "ncsu-nclive-1999": "nclive-2000", "ncsu-1998": "ncsu-block-s", "ziff-davis-1994": "ziff-davis-1990", "interpath-1998": "interpath", "db-basics-1994": "placeholder", "pioneer-software-1992": "qe-software", "roemer-weather-1992": "roemer-weather", "ncsu-ta-1990": "ncsu-classic-1990", "ncsu-library-1990": "ncsu-classic-1990", "ncsu-operator-1990": "ncsu-classic-1990"} %>
<% for job in experiences.info %>
\jobtitle{<< job.role | latex_escape >>}{<< job.time >>}{<< job.company | latex_escape >>}{<< exp_logo_map.get(job.anchor, "placeholder") >>}

<% if job.summary %>
{\small << job.summary | latex_escape | latex_paragraphs >>}
<% endif %>

<% if job.details %>
{\small << job.details | latex_escape | latex_paragraphs >>}
<% endif %>

<% if job.subsections %>
<% for sub in job.subsections %>
\needspace{3\baselineskip}
\subsubsection{<< sub.title | latex_escape >>}
{\small << sub.text | latex_escape | latex_paragraphs >>}

<% endfor %>
<% endif %>

<% endfor %>

% === CERTIFICATIONS ===
\needspace{6\baselineskip}
\section{Certifications}
<% for cert in certifications.list %>
\needspace{2\baselineskip}
\noindent\textbf{<< cert.name | latex_escape >>} \hfill {\small\textcolor{subtext}{<< cert.start >><% if cert.end %> -- << cert.end >><% endif %>}}\\
{\small << cert.organization | latex_escape >><% if cert.credentialid %> (<< cert.credentialid >>)<% endif %><% if cert.credentialurl %> \hfill \href{<< cert.credentialurl >>}{Verify on << cert.credentialname | default("web") >>}<% endif %>}
\vspace{4pt}

<% endfor %>

% === PROJECTS ===
\needspace{6\baselineskip}
\section{Projects}
<% if projects.intro %>
{\small << projects.intro | latex_escape | latex_paragraphs >>}
\vspace{4pt}
<% endif %>
<% for project in projects.assignments %>
\needspace{3\baselineskip}
<% if project.link %>
\noindent\textbf{\href{<< project.link >>}{<< project.title | latex_escape >>}}<% if project.time %> \hfill {\small\textcolor{subtext}{<< project.time >>}}<% endif %>\\
<% else %>
\noindent\textbf{<< project.title | latex_escape >>}<% if project.time %> \hfill {\small\textcolor{subtext}{<< project.time >>}}<% endif %>\\
<% endif %>
{\small\color{subtext} << project.tagline | latex_escape | latex_paragraphs >>}
\vspace{4pt}

<% endfor %>

% === PUBLICATIONS ===
<% if publications and publications.papers %>
\needspace{6\baselineskip}
\section{Publications}
<% for pub in publications.papers %>
<% if pub.link %>
\textbf{\href{<< pub.link >>}{<< pub.title | latex_escape >>}}. << pub.authors | latex_escape >>. \textit{<< pub.conference | latex_escape >>}.
<% else %>
\textbf{<< pub.title | latex_escape >>}. << pub.authors | latex_escape >>. \textit{<< pub.conference | latex_escape >>}.
<% endif %>
<% endfor %>
<% endif %>

% === SKILLS ===
\clearpage
\section{Skills \& Proficiency}
\begin{multicols}{2}
\raggedcolumns
<% for skillset in skills.skillsets %>
\begin{minipage}{\columnwidth}
{\normalsize\bfseries << skillset.categories | latex_escape >>}
\vspace{2pt}

<% for sub in skillset.sub_categories %>
\hspace{0.4em}{\small\itshape << sub.title | latex_escape >>}\\[0pt]
\hspace{1.2em}{\footnotesize\color{subtext} << sub.list | latex_escape >>}
\vspace{3pt}

<% if sub.sub_sub_categories %>
<% for subsub in sub.sub_sub_categories %>
\hspace{1.6em}{\footnotesize\itshape << subsub.title | latex_escape >>}\\[0pt]
\hspace{2.4em}{\scriptsize\color{subtext} << subsub.list | latex_escape >>}
\vspace{2pt}

<% endfor %>
<% endif %>
<% endfor %>
\end{minipage}
\vspace{5pt}

<% endfor %>
\end{multicols}

% === PROFILES & LINKS ===
\clearpage
\section{Profiles \& Links}
\begin{multicols}{2}
\begin{itemize}
<% if sidebar.website %>
  \item \textbf{Website:} \href{https://<< sidebar.website >>}{www.<< sidebar.website | replace("www.", "") >>}
<% endif %>
<% if sidebar.linkedin %>
  \item \textbf{LinkedIn:} \href{https://linkedin.com/in/<< sidebar.linkedin >>}{linkedin.com/in/<< sidebar.linkedin >>}
<% endif %>
<% if sidebar.github %>
  \item \textbf{GitHub:} \href{https://github.com/<< sidebar.github >>}{github.com/<< sidebar.github >>}
<% endif %>
<% if sidebar.gitlab %>
  \item \textbf{GitLab:} \href{https://gitlab.com/<< sidebar.gitlab >>}{gitlab.com/<< sidebar.gitlab >>}
<% endif %>
<% if sidebar.kaggle %>
  \item \textbf{Kaggle:} \href{https://www.kaggle.com/<< sidebar.kaggle >>}{kaggle.com/<< sidebar.kaggle >>}
<% endif %>
<% if sidebar.substack %>
  \item \textbf{Substack:} \href{https://<< sidebar.substack >>.substack.com/}{<< sidebar.substack >>.substack.com}
<% endif %>
<% if sidebar.get("stack-overflow") %>
  \item \textbf{Stack Overflow:} \href{https://stackoverflow.com/users/<< sidebar["stack-overflow"] >>}{stackoverflow.com}
<% endif %>
<% if sidebar.signal %>
  \item \textbf{Signal:} @<< sidebar.signal >>
<% endif %>
\end{itemize}
\end{multicols}

\vspace{12pt}
\begin{center}
{\small\color{subtext}
  Full interactive resume at: \href{https://mcgarrah.org/resume/}{https://mcgarrah.org/resume/}
}
\end{center}

\vspace{8pt}
\begin{center}
{\small\color{subtext} Generated on << generation_date >>}
\end{center}

\end{document}
